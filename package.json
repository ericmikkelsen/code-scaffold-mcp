{
  "name": "code-scaffold-mcp",
  "version": "1.2.0",
  "description": "A scaffold-first system for generating function, component, and schema templates",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "node --import tsx/esm --test src/*.test.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test:coverage": "node --import tsx/esm --experimental-test-coverage --test src/*.test.ts",
    "benchmark:ts": "BENCH_BASE_URL=${BENCH_BASE_URL:-http://localhost:11434/v1} BENCH_MODEL=${BENCH_MODEL:-gemma4} BENCH_CONDITIONS=bare,scaffolded BENCH_LOG_PROMPTS=1 node --import tsx/esm benchmarks/run.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "scaffold",
    "codegen",
    "mcp",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ericmikkelsen/code-scaffold-mcp.git"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "openai": "^4.77.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "type": "module"
}
